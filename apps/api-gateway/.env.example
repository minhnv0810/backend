NODE_ENV=development
PORT=3000

# RS256 public key (PEM, collapse newlines to \n)
# Generate: openssl rsa -pubout -in private.pem -out public.pem
# Encode:   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' public.pem
JWT_PUBLIC_KEY=
JWT_AUDIENCE=ecommerce-api
JWT_ISSUER=auth-service

# Upstream services
AUTH_SERVICE_URL=http://localhost:3001
PRODUCT_SERVICE_URL=http://localhost:3002
ORDERS_SERVICE_URL=http://localhost:3003

UPSTREAM_TIMEOUT_MS=10000
CORS_ORIGINS=http://localhost:4200

THROTTLE_GLOBAL_LIMIT=100
THROTTLE_GLOBAL_TTL_MS=60000
THROTTLE_AUTH_LIMIT=10
THROTTLE_AUTH_TTL_MS=60000

LOG_LEVEL=debug
