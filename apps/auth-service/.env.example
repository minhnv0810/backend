NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_db

RABBITMQ_URL=amqp://rabbit:rabbit@localhost:5672
RABBITMQ_EXCHANGE=domain.events

# RS256 key pair
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
# Then:     openssl rsa -pubout -in private.pem -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
JWT_AUDIENCE=ecommerce-api
JWT_ISSUER=auth-service

LOG_LEVEL=debug
