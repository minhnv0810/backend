NODE_ENV=development
PORT=3002

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_db

RABBITMQ_URL=amqp://rabbit:rabbit@localhost:5672
RABBITMQ_EXCHANGE=domain.events

# RS256 public key from auth-service (used for JWT verification)
# Copy from auth-service JWT_PUBLIC_KEY
JWT_PUBLIC_KEY=
JWT_AUDIENCE=ecommerce-api
JWT_ISSUER=auth-service

LOG_LEVEL=debug
